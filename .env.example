# ============================================================
# HiSpark Studio AI — E2E Test Environment Variables
# ============================================================
# Copy this file to .env and fill in the values for your machine.
# Never commit .env to version control.

# Absolute path to the VSCode / VSCodium Electron executable.
#
# macOS default:
#   /Applications/Visual Studio Code.app/Contents/MacOS/Electron
#
# Windows default (adjust drive letter / install location as needed):
#   C:\Program Files\Microsoft VS Code\Code.exe
#
# Linux default:
#   /usr/share/code/code
#
VSCODE_EXECUTABLE_PATH=

# Absolute path to the extension source root — the directory that contains
# code/package.json and code/dist/. On both Mac and Windows this should be
# the repo-root/code directory resolved to an absolute path.
#
# Example (Mac/Linux):
#   /Users/yourname/2026/HiSparkAI/code
#
# Example (Windows):
#   C:\Users\yourname\2026\HiSparkAI\code
#
EXTENSION_DEVELOPMENT_PATH=

# Absolute path to the data directory containing calibration/validation
# inputs used by the quantization tests.
#
# Example (Mac/Linux):
#   /Users/yourname/2026/HiSparkAI/data
#
# Example (Windows):
#   C:\Users\yourname\2026\HiSparkAI\data
#
DATA_DIR=

# Path to the SDK workspace folder that VSCode will open at launch.
# This folder must already exist on disk and must contain the sentinel file
# that tells the extension which target to activate:
#   CPU: <WORKSPACE_PATH>\build\config\target_config\ws63\ws63.json
#   NPU: <WORKSPACE_PATH>\build\config\target_config\3322\3322.json
#
# Without this, the extension opens in target=NONE (WelcomePage) and
# the chip config UI never appears.
#
# Example (Windows):
#   WORKSPACE_PATH=D:\tsuki\SDK\ws63
#
# Example (Mac/Linux):
#   WORKSPACE_PATH=/home/yourname/sdk/ws63
#
WORKSPACE_PATH=
